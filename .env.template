# Kraken API Credentials Configuration
#
# SECURITY WARNING:
# - This file is a TEMPLATE - copy it to .env and fill in your actual credentials
# - NEVER commit .env to version control (it's in .gitignore)
# - Keep your API keys secure and never share them
#
# Setup Instructions:
# 1. Copy this file: cp .env.template .env
# 2. Edit .env with your actual credentials
# 3. Verify .env is NOT tracked by git: git status
#
# How to get these values:
# - API Keys: Kraken web → Settings → API → Generate New Key
#   - Master key MUST have "Query Funds" and "Withdraw" permissions
#   - Subaccount keys only need "Query Funds" (for balance checking)
# - IIBANs: Kraken web → Settings → API → Account identifiers
#   - Format: AAXX XXXX XXXX XXXX (4 groups of 4 characters with spaces)
#   - Each account (master and subaccounts) has a unique IIBAN

# ============================================================================
# MASTER ACCOUNT (REQUIRED)
# ============================================================================
# Master account API key - MUST have "Withdraw" permission enabled
# This is used to initiate all transfers
KRAKEN_API_KEY_MASTER=your_master_api_key_here
KRAKEN_API_SECRET_MASTER=your_master_api_secret_here

# Master account IIBAN (Account identifier)
# Example format: AA01 N84G FVOT ZYAA (from Kraken API docs)
KRAKEN_IIBAN_MASTER=AA01 XXXX XXXX XXXX

# ============================================================================
# STAGING SUBACCOUNT
# ============================================================================
# Staging subaccount API key (can be read-only, only needs "Query Funds")
KRAKEN_API_KEY_STAGING=your_staging_api_key_here
KRAKEN_API_SECRET_STAGING=your_staging_api_secret_here

# Staging subaccount IIBAN
# Example format: AA02 N84G AHGV XD4A (from Kraken API docs)
KRAKEN_IIBAN_STAGING=AA02 XXXX XXXX XXXX

# ============================================================================
# PRODUCTION SUBACCOUNT
# ============================================================================
# Production subaccount API key (can be read-only, only needs "Query Funds")
KRAKEN_API_KEY_PRODUCTION=your_production_api_key_here
KRAKEN_API_SECRET_PRODUCTION=your_production_api_secret_here

# Production subaccount IIBAN
# Example format: AA03 N84G AHGV XD4B (from Kraken API docs)
KRAKEN_IIBAN_PRODUCTION=AA03 XXXX XXXX XXXX

# ============================================================================
# NOTES
# ============================================================================
#
# Account Naming:
# - You can use different names (e.g., "MAIN", "DEV", "PROD")
# - Just update the suffixes in the notebook to match
# - Suffixes are the part after KRAKEN_API_KEY_ or KRAKEN_IIBAN_
#
# Security:
# - Master API key is the most sensitive - protect it carefully
# - Consider using API key restrictions (e.g., IP allowlist) in Kraken settings
# - Rotate API keys periodically
# - Never share or screenshot this file with real credentials
#
# Kraken Asset Codes:
# - USD = ZUSD
# - Bitcoin = XXBT
# - Ethereum = XETH
# - Check your balance to see exact asset names
#
